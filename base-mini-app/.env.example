# ============================================================================
# Vaultfire Base Mini App - Environment Variables
# ============================================================================
#
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# IMPORTANT: Never commit .env.local to git (already in .gitignore)
#
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED: WalletConnect Configuration
# ----------------------------------------------------------------------------
# Get your Project ID from: https://cloud.walletconnect.com
# Required for RainbowKit wallet connection
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ----------------------------------------------------------------------------
# REQUIRED: Vaultfire Smart Contracts (Base Mainnet)
# ----------------------------------------------------------------------------
# DilithiumAttestor contract address (handles belief attestations)
NEXT_PUBLIC_DILITHIUM_ATTESTOR_ADDRESS=

# BeliefAttestationVerifier contract address (RISC Zero STARK verification)
NEXT_PUBLIC_BELIEF_VERIFIER_ADDRESS=

# ----------------------------------------------------------------------------
# OPTIONAL: Custom RPC Configuration
# ----------------------------------------------------------------------------
# Base Mainnet RPC (defaults to https://mainnet.base.org)
# NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# Base Sepolia Testnet RPC (for testing)
# NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ----------------------------------------------------------------------------
# OPTIONAL: Network Configuration
# ----------------------------------------------------------------------------
# Enable testnet networks (default: false in production)
# NEXT_PUBLIC_ENABLE_TESTNETS=false

# Default chain ID (8453 = Base Mainnet, 84532 = Base Sepolia)
# NEXT_PUBLIC_DEFAULT_CHAIN_ID=8453

# ----------------------------------------------------------------------------
# OPTIONAL: Analytics & Monitoring
# ----------------------------------------------------------------------------
# Sentry DSN for error tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=

# Environment name (development, staging, production)
# NEXT_PUBLIC_ENV=production

# ----------------------------------------------------------------------------
# OPTIONAL: Feature Flags
# ----------------------------------------------------------------------------
# Enable debug mode (shows additional logging)
# NEXT_PUBLIC_DEBUG=false

# Enable mock proofs (for development without RISC Zero)
# NEXT_PUBLIC_USE_MOCK_PROOFS=false

# ============================================================================
# Deployment Checklist
# ============================================================================
#
# Before deploying to production:
#   1. ✅ Get WalletConnect Project ID
#   2. ✅ Deploy Vaultfire contracts to Base Mainnet
#   3. ✅ Update contract addresses above
#   4. ✅ Set NEXT_PUBLIC_ENABLE_TESTNETS=false
#   5. ✅ Configure error tracking (Sentry)
#   6. ✅ Test wallet connection on staging
#   7. ✅ Verify all environment variables are set
#
# ============================================================================
