# ============================================
# Vaultfire Base Mini App - Environment Variables
# ============================================

# Required: WalletConnect Project ID
# Get your free project ID from: https://cloud.walletconnect.com
# This enables wallet connections via RainbowKit
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Required: Vaultfire Contract Addresses (Base Mainnet)
# Deploy contracts first, then add addresses here
# DilithiumAttestor handles belief attestations with ZK proofs
NEXT_PUBLIC_DILITHIUM_ATTESTOR_ADDRESS=0x0000000000000000000000000000000000000000

# BeliefVerifier handles STARK proof verification
NEXT_PUBLIC_BELIEF_VERIFIER_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: Custom Base RPC URL
# Leave empty to use public RPC (not recommended for production)
# Get a dedicated RPC from Alchemy, Infura, or QuickNode
NEXT_PUBLIC_BASE_RPC_URL=

# Optional: Analytics & Error Tracking
# Uncomment and configure if using Sentry, PostHog, etc.
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=

# Production Deployment Checklist:
# 1. Set NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID
# 2. Deploy contracts and set addresses above
# 3. Configure custom RPC for better reliability
# 4. Set up error tracking (Sentry recommended)
# 5. Enable analytics (PostHog/Mixpanel recommended)
# 6. Test on Base Sepolia testnet first
