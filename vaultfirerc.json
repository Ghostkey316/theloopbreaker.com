{
  "trustSync": {
    "identityStore": {
      "provider": "memory",
      "breachThreshold": 0.35,
      "postgres": {
        "connection": {
          "connectionString": "postgres://vaultfire:secret@localhost:5432/vaultfire"
        }
      },
      "mongo": {
        "connection": {
          "uri": "mongodb://localhost:27017/vaultfire"
        }
      }
    },
    "telemetry": {
      "baseDir": "./logs/telemetry",
      "fallback": {
        "enabled": true,
        "fileName": "remote-fallback.jsonl"
      },
      "residency": {
        "enforce": true,
        "defaultRegion": "eu-central-1",
        "allowLocalhost": false,
        "telemetry": {
          "eu-central-1": [
            "o*.ingest.sentry.io",
            "telemetry.eu.vaultfire.xyz"
          ],
          "us-west-2": [
            "o*.ingest.sentry.io",
            "telemetry.us.vaultfire.xyz"
          ]
        },
        "partnerHooks": {
          "eu-central-1": [
            "hooks.eu.vaultfire.xyz",
            "partners.eu.vaultfire.xyz",
            "*.partners.eu.vaultfire.xyz"
          ],
          "us-west-2": [
            "hooks.us.vaultfire.xyz",
            "partners.us.vaultfire.xyz",
            "*.partners.us.vaultfire.xyz"
          ]
        },
        "globalAllowList": [
          "telemetry.vaultfire.xyz"
        ]
      }
    },
    "telemetry-fallback": true,
    "signalCompass": {
      "retentionLimit": 200
    },
    "mirror": {
      "outputChannel": "cli"
    },
    "verification": {
      "remote": {
        "endpoint": "https://verification.invalid/anchor",
        "apiKey": "starter-key"
      },
      "externalValidationEndpoint": "https://attest.vaultfire.test/partners"
    }
  },
  "hooks": {
    "defaultSubscriptions": [
      {
        "event": "activation",
        "targetUrl": "https://partners.example.com/hooks/vaultfire/activation"
      }
    ]
  },
  "rewards": {
    "fallbackMultiplier": 1,
    "multiplierAddress": "0x0000000000000000000000000000000000000000",
    "rewardStreamAddress": "0x0000000000000000000000000000000000000000",
    "providerUrl": "http://localhost:8545",
    "stream": {
      "autoDistribute": false
    }
  }
}
