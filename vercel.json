{
  "builds": [
    {
      "src": "demos/vaultfire_demo.py",
      "use": "vercel-python@0.5.4",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "demos/vaultfire_demo.py"
    }
  ],
  "env": {
    "STREAMLIT_SERVER_PORT": "0",
    "STREAMLIT_SERVER_HEADLESS": "true"
  },
  "functions": {
    "demos/vaultfire_demo.py": {
      "runtime": "python3.11",
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "**"
    }
  },
  "devCommand": "streamlit run demos/vaultfire_demo.py --server.port $PORT --server.address 0.0.0.0"
}
