# ═══════════════════════════════════════════════════════
# Embris by Vaultfire Protocol — Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── LLM / Companion Brain ──
# OpenAI-compatible API key for the Embris Companion brain.
# Used by stream-chat.ts for conversation generation.
NEXT_PUBLIC_OPENAI_API_KEY=

# Optional: Override the LLM API endpoint (defaults to OpenAI).
# NEXT_PUBLIC_LLM_API_URL=https://api.openai.com/v1/chat/completions

# ── App URL ──
# Public URL of the deployed app (used for API routes).
NEXT_PUBLIC_API_URL=http://localhost:3000

# ── Deployer Key (server-side only) ──
# Used ONLY as an environment variable for server-side agent operations.
# NEVER hardcode this value in any source file.
# DEPLOYER_PRIVATE_KEY=

# ── Etherscan / BaseScan API Key ──
# Used for contract verification (not required at runtime).
# ETHERSCAN_API_KEY=
