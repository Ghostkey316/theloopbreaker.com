# Vaultfire live oracle configuration
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET=your-pinata-secret
BASE_RPC_URL=https://base-mainnet.example
PRIVATE_KEY=0xabc123privatekey

# --- ERC-8128 (Signed HTTP Requests with Ethereum) ---
# Required to enable ERC-8128 auth in auth/expressExample.js
VAULTFIRE_REDIS_URL=redis://localhost:6379

# RPC endpoints used for ERC-1271 (smart contract wallet) verification.
# Set the ones you actually need.
VAULTFIRE_RPC_MAINNET=https://eth-mainnet.example
VAULTFIRE_RPC_BASE=https://base-mainnet.example
VAULTFIRE_RPC_SEPOLIA=https://sepolia.example
VAULTFIRE_RPC_BASE_SEPOLIA=https://base-sepolia.example
BASE_ORACLE_ADDRESS=0x0000000000000000000000000000000000000000
MISSION_RESONANCE_THRESHOLD=0.72
DRIFT_THRESHOLD=0.15
