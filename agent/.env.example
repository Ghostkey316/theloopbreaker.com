# ═══════════════════════════════════════════════════════════════════════════════
#  Vaultfire Sentinel Agent — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════

# ── Wallet Private Key ───────────────────────────────────────────────────────────
# The private key of the wallet that will run the agent, register it, and relay
# bridge messages. This wallet MUST have ETH on Base and AVAX on C-Chain for gas.
# The deployer key is the default, but any key can be used.
# IMPORTANT: DO NOT COMMIT THIS KEY TO GIT. This is a secret.
DEPLOYER_KEY="e189d7fa3c02b2716d78d97002654f953604bb28f14b662b4e410a395da8d410"

# ── RPC Endpoints ────────────────────────────────────────────────────────────────
# Optional: Override the default public RPC endpoints. For production, it is
# highly recommended to use a dedicated RPC provider (e.g., Alchemy, Infura).
BASE_RPC="https://mainnet.base.org"
AVAX_RPC="https://api.avax.network/ext/bc/C/rpc"

# ── Logging & Timing ─────────────────────────────────────────────────────────────
# LOG_LEVEL: DEBUG, INFO, WARN, ERROR, CRITICAL (default: INFO)
LOG_LEVEL="INFO"

# POLL_INTERVAL_MS: How often to poll for new blocks/events (default: 12000)
POLL_INTERVAL_MS="12000"

# HEALTH_CHECK_MS: How often to print a health summary (default: 300000)
HEALTH_CHECK_MS="300000"
