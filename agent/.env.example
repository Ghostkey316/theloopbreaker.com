# ============================================================
# Vaultfire Agent Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit your .env file or expose private keys.
# ============================================================

# --- Wallet ---
# The agent's own private key on Base mainnet.
# Generate a fresh wallet for the agent; fund it with a small amount of ETH for gas.
AGENT_PRIVATE_KEY=

# --- RPC ---
# Base mainnet RPC endpoint. Public endpoint works but a dedicated one is recommended.
BASE_RPC_URL=https://mainnet.base.org

# --- Partner ---
# The human partner's wallet address (deployer wallet).
HUMAN_PARTNER_ADDRESS=0xf6A677de83C407875C9A9115Cf100F121f9c4816

# --- Agent Identity ---
# URI pointing to the agent's metadata (IPFS, HTTPS, or data URI).
AGENT_URI=https://vaultfire.io/agents/vaultfire-sentinel
# The type classification for this agent.
AGENT_TYPE=autonomous-sentinel
# Human-readable name for the agent.
AGENT_NAME=Vaultfire Sentinel

# --- Operation Mode ---
# Set to "true" to simulate all transactions without sending them on-chain.
DRY_RUN=true

# --- Task Loop ---
# Interval in seconds between task loop cycles (default: 300 = 5 minutes).
TASK_INTERVAL_SECONDS=300

# --- Logging ---
# Log level: debug, info, warn, error
LOG_LEVEL=info
