{
  "name": "ghostkey-316-vaultfire-init",
  "version": "1.2.0-rc",
  "description": "**This system is not built for profit. It is built for people.**",
  "main": "manifesto_broadcast.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "jest --coverage --runInBand --detectOpenHandles && node tools/generateCoverageBadge.js",
    "test:coverage": "jest --coverage",
    "coverage:sonar": "node tools/sonar-coverage-stub.js",
    "signal-shield": "node vaultfire_signal_shield/index.js",
    "start:api": "node auth/expressExample.js",
    "dashboard:dev": "vite --config dashboard/vite.config.mjs",
    "dashboard:build": "vite build --config dashboard/vite.config.mjs",
    "dev:arcade": "cd apps/vaultfire-arcade && npm run dev",
    "build:arcade": "cd apps/vaultfire-arcade && npm run build",
    "build": "node tools/update-version.js && npm run dashboard:build",
    "build:test": "tsc --project tsconfig.json --noEmit",
    "lint:guardrails": "node tools/lint_guardrails.js",
    "lint:values": "node tools/lint_values_guardrails.js",
    "gen:privileged-surface": "node tools/generate_privileged_surface.js",
    "lint:privileged-surface": "node tools/check_privileged_surface.js",
    "gen:events-surface": "node tools/generate_events_surface.js",
    "lint:events-surface": "node tools/check_events_surface.js",
    "gen:external-calls": "node tools/generate_external_calls_surface.js",
    "lint:external-calls": "node tools/check_external_calls_surface.js",
    "gen:storage-growth": "node tools/generate_storage_growth_surface.js",
    "lint:storage-growth": "node tools/check_storage_growth_surface.js",
    "lint:syntax": "node tools/run-eslint-syntax.js",
    "lint:claim-map": "node tools/claim_map_check.js",
    "preflight": "node tools/preflight-check.js",
    "postinstall": "node scripts/check-mobile-optional.js",
    "deploy:sandbox": "node cli/deployVaultfire.js --env sandbox",
    "deploy:production": "node cli/deployVaultfire.js --env production",
    "telemetry:verify": "node tools/telemetry_verify.js",
    "audit": "npm audit --audit-level=high",
    "audit:gov": "node governance/governance-core.js --audit",
    "security:watch": "node tools/security-watch.js",
    "drift:scan": "node cli/drift_anchor_verifier.js",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.8",
    "@openzeppelin/contracts": "^5.4.0",
    "@sentry/react": "^10.28.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@vitejs/plugin-react": "^5.0.4",
    "ajv-formats": "^3.0.1",
    "babel-jest": "^29.6.1",
    "baseline-browser-mapping": "^2.9.19",
    "commander": "^12.1.0",
    "eslint": "^9.12.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.2",
    "express": "^4.22.1",
    "express-rate-limit": "^6.11.2",
    "hardhat": "^2.22.7",
    "husky": "^9.1.6",
    "jest": "^29.6.1",
    "jest-fetch-mock": "^3.0.3",
    "jsonwebtoken": "^9.0.2",
    "mock-fs": "^5.5.0",
    "mongodb": "^5.9.2",
    "prom-client": "^15.1.3",
    "sentiment": "^5.0.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "supertest": "^6.3.4",
    "swagger-ui-express": "^4.6.3",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.11",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "wrap-ansi": "^7.0.0",
    "yamljs": "^0.3.0"
  },
  "overrides": {
    "axios": "^1.13.5"
  }
}
