# Vaultfire Mainnet Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ============================================================================
# DEPLOYER WALLET
# ============================================================================

# Private key for deployment (needs ~0.5 ETH on Base Mainnet)
# WARNING: Keep this secret! Never share or commit to git
PRIVATE_KEY=your_deployer_private_key_here

# ============================================================================
# NETWORK CONFIGURATION
# ============================================================================

# Base Mainnet RPC URL
BASE_RPC_URL=https://mainnet.base.org
# Alternative RPC providers:
# BASE_RPC_URL=https://base.llamarpc.com
# BASE_RPC_URL=https://base.blockpi.network/v1/rpc/public

# Basescan API Key (for contract verification)
# Get one at: https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key_here

# ============================================================================
# MULTISIG ADDRESSES (Gnosis Safe)
# ============================================================================
# Fill these in after creating your Gnosis Safe wallets
# See: deployment/MAINNET_MULTISIG_SETUP.md

GOVERNANCE_MULTISIG=0xYOUR_GOVERNANCE_SAFE_ADDRESS
OPERATIONS_MULTISIG=0xYOUR_OPERATIONS_SAFE_ADDRESS
TREASURY_MULTISIG=0xYOUR_TREASURY_SAFE_ADDRESS

# ============================================================================
# RISC ZERO CONFIGURATION (for ZK proofs)
# ============================================================================

# RISC Zero Bonsai API Key
# Get one at: https://bonsai.xyz
RISC_ZERO_API_KEY=your_bonsai_api_key_here

# Bonsai Prover URL
RISC_ZERO_PROVER_URL=https://api.bonsai.xyz

# ============================================================================
# ORACLE CONFIGURATION
# ============================================================================

# Entropy source for BeliefOracle (can be any address for determinism)
# Default: 0x0000000000000000000000000000000000000042
GHOST_ECHO_ADDRESS=0x0000000000000000000000000000000000000042

# ============================================================================
# FRONTEND CONFIGURATION (for Next.js apps)
# ============================================================================

# WalletConnect Project ID
# Get one at: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Network settings
NEXT_PUBLIC_DEFAULT_CHAIN_ID=8453
NEXT_PUBLIC_ENABLE_TESTNETS=false
NEXT_PUBLIC_ENV=production

# ZK Proof settings (CRITICAL: must be false in production)
NEXT_PUBLIC_USE_MOCK_PROOFS=false

# ============================================================================
# MONITORING & ERROR TRACKING
# ============================================================================

# Sentry DSN (optional but recommended)
# Get one at: https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# ============================================================================
# DEPLOYMENT SETTINGS
# ============================================================================

# Gas price multiplier (1.0 = normal, 1.5 = 50% faster)
GAS_PRICE_MULTIPLIER=1.2

# Confirmation blocks to wait
CONFIRMATIONS=3

# ============================================================================
# CONTRACT ADDRESSES (filled in after deployment)
# ============================================================================

# Core Contracts
REWARD_STREAM_ADDRESS=
DILITHIUM_ATTESTOR_ADDRESS=
BELIEF_ORACLE_ADDRESS=
MULTI_ORACLE_CONSENSUS_ADDRESS=

# Bond Contracts
BUILDER_BELIEF_BONDS_V2_ADDRESS=
LABOR_DIGNITY_BONDS_V2_ADDRESS=
PURCHASING_POWER_BONDS_V2_ADDRESS=
AI_ACCOUNTABILITY_BONDS_V2_ADDRESS=
HEALTH_COMMONS_BONDS_V2_ADDRESS=
ESCAPE_VELOCITY_BONDS_V2_ADDRESS=
AI_PARTNERSHIP_BONDS_V2_ADDRESS=
COMMON_GROUND_BONDS_V2_ADDRESS=
VERDANT_ANCHOR_BONDS_V2_ADDRESS=

# Additional Contracts
REWARD_MULTIPLIER_ADDRESS=
CONTRIBUTOR_UNLOCK_KEY_ADDRESS=

# ============================================================================
# FRONTEND DEPLOYMENT (Vercel/Netlify)
# ============================================================================

# Vercel deployment (optional)
VERCEL_TOKEN=your_vercel_token_here
VERCEL_ORG_ID=your_vercel_org_id_here
VERCEL_PROJECT_ID=your_vercel_project_id_here

# ============================================================================
# SECURITY NOTES
# ============================================================================

# IMPORTANT:
# 1. Never commit .env to git (.env is in .gitignore)
# 2. Use different private keys for testnet and mainnet
# 3. Store private keys securely (hardware wallet, encrypted vault)
# 4. Rotate API keys regularly
# 5. Use environment-specific .env files (.env.local, .env.production)
# 6. Never share your private key or mnemonic with anyone
# 7. Always verify contract addresses before interacting
# 8. Test on testnet (Base Sepolia) before mainnet deployment

# ============================================================================
# CHECKLIST BEFORE DEPLOYMENT
# ============================================================================

# [ ] PRIVATE_KEY is set and wallet is funded with 0.5+ ETH
# [ ] BASE_RPC_URL is working (test with curl)
# [ ] BASESCAN_API_KEY is valid
# [ ] All three multisig addresses are set
# [ ] Multisigs are deployed on Base Mainnet
# [ ] RISC_ZERO_API_KEY is valid (test ZK proof generation)
# [ ] WALLETCONNECT_PROJECT_ID is valid
# [ ] Sentry configured (optional but recommended)
# [ ] All testnets disabled (NEXT_PUBLIC_ENABLE_TESTNETS=false)
# [ ] Mock proofs disabled (NEXT_PUBLIC_USE_MOCK_PROOFS=false)
# [ ] Reviewed all settings above
# [ ] Made backup of this file in secure location
# [ ] Ready for mainnet deployment!
