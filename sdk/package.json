{
  "name": "@vaultfire/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for Vaultfire - The Trust Layer for Base. Verify any claim with zero-knowledge proofs.",
  "main": "dist/vaultfire.js",
  "types": "dist/vaultfire.d.ts",
  "module": "dist/vaultfire.js",
  "bin": {
    "vaultfire-api": "dist/api-server.js"
  },
  "files": [
    "dist",
    "README.md",
    "API_REFERENCE.md",
    "examples"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/api-server.js 2>/dev/null || true",
    "dev": "tsc --watch",
    "test": "echo \"Tests pending\" && exit 0",
    "prepublishOnly": "npm run build",
    "api": "node dist/api-server.js",
    "example:defi": "ts-node examples/defi-trading.ts",
    "example:dao": "ts-node examples/governance-dao.ts"
  },
  "keywords": [
    "vaultfire",
    "sdk",
    "attestation",
    "zk-proof",
    "zero-knowledge",
    "stark",
    "risc-zero",
    "base",
    "blockchain",
    "trust-layer",
    "reputation",
    "identity",
    "credentials",
    "governance",
    "defi",
    "web3"
  ],
  "author": "Vaultfire <support@vaultfire.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ghostkey316/ghostkey-316-vaultfire-init.git",
    "directory": "sdk"
  },
  "bugs": {
    "url": "https://github.com/Ghostkey316/ghostkey-316-vaultfire-init/issues"
  },
  "homepage": "https://vaultfire.io",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "ethers": "^6.10.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "ts-node": "^10.9.2",
    "ts-jest": "^29.1.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
