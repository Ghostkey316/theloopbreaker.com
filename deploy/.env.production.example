# Vaultfire production deployment
NODE_ENV=production
API_BASE_URL=https://api.vaultfire.network
TELEMETRY_PERSISTENCE=postgres
TELEMETRY_CONNECTION=postgres://vaultfire:secure@db:5432/telemetry
WEBHOOK_RELAY_JITTER=0.2
REWARD_STREAM_MODE=live
JWT_ISSUER=https://auth.vaultfire.network
JWT_AUDIENCE=vaultfire-partner-production
